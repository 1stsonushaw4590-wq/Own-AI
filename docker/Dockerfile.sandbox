FROM kalilinux/kali-rolling:latest

LABEL description="Cyber-LLM Sandbox — Kali Linux with lightweight security tools"

ENV DEBIAN_FRONTEND=noninteractive

# Install lightweight tools only (no heavy frameworks like metasploit)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    gcc g++ ca-certificates strace curl wget \
    nmap sqlmap \
    nikto \
    hydra \
    john \
    dirb \
    netcat-openbsd \
    jq bind9-dnsutils \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /sandbox/venv

WORKDIR /sandbox
COPY run.py /sandbox/run.py

CMD ["python3", "/sandbox/run.py", "--serve"]
