#!/usr/bin/env bash
# Pre-commit hook: runs tests + lint checks before allowing a commit.
# Install: make install-hooks (or: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x)
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "=== pre-commit: running tests ==="
. .venv/bin/activate 2>/dev/null || true

# Quick syntax check on all Python files
ERRORS=0
for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$'); do
    python3 -m py_compile "$f" 2>/dev/null || { echo "SYNTAX ERROR: $f"; ERRORS=1; }
done
[ $ERRORS -eq 1 ] && { echo "Fix syntax errors before committing."; exit 1; }

# Run the test suite
python3 -m pytest tests/ -q --tb=short 2>/dev/null || { echo "Tests failed. Fix before committing."; exit 1; }

echo "=== pre-commit: all checks passed ==="
