    "# Cell 7 (Alternative): Manual merge if script fails\n",
    "import torch\n",
    "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
    "from peft import PeftModel\n",
    "\n",
    "print(\"Loading base model...\")\n",
    "tokenizer = AutoTokenizer.from_pretrained(\n",
    "    \"Qwen/Qwen2.5-Coder-7B-Instruct\", trust_remote_code=True\n",
    ")\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    \"Qwen/Qwen2.5-Coder-7B-Instruct\",\n",
    "    torch_dtype=torch.float16,\n",
    "    device_map=\"auto\",\n",
    "    trust_remote_code=True,\n",
    ")\n",
    "\n",
    "print(\"Loading adapter...\")\n",
    "model = PeftModel.from_pretrained(model, \"/kaggle/working/qwen25-coder-7b-cyber/adapter\")\n",
    "\n",
    "print(\"Merging adapter...\")\n",
    "model = model.merge_and_unload()\n",
    "\n",
    "print(\"Saving merged model...\")\n",
    "model.save_pretrained(\"/kaggle/working/qwen25-coder-7b-cyber/merged\", safe_serialization=True)\n",
    "tokenizer.save_pretrained(\"/kaggle/working/qwen25-coder-7b-cyber/merged\")\n",
    "print(\"✅ Merge complete!\")"
   ]
