    "# Cell 8: Convert to GGUF (requires llama.cpp)\n",
    "# Note: Run this only if llama.cpp is available\n",
    "# Otherwise download the merged model and convert locally\n",
    "\n",
    "# Check if llama.cpp is available\n",
    "import subprocess\n",
    "import sys\n",
    "\n",
    "llama_cpp_paths = [\n",
    "    \"/tmp/opencode/llama.cpp/convert_hf_to_gguf.py\",\n",
    "    \"/usr/local/llama.cpp/convert_hf_to_gguf.py\",\n",
    "    os.path.expanduser(\"~/llama.cpp/convert_hf_to_gguf.py\"),\n",
    "]\n",
    "\n",
    "convert_script = None\n",
    "for p in llama_cpp_paths:\n",
    "    if os.path.exists(p):\n",
    "        convert_script = p\n",
    "        break\n",
    "\n",
    "if convert_script:\n",
    "    print(f\"Found convert script: {convert_script}\")\n",
    "    \n",
    "    # Convert to f16\n",
    "    cmd = [\n",
    "        sys.executable, convert_script,\n",
    "        \"/kaggle/working/qwen25-coder-7b-cyber/merged\",\n",
    "        \"--outfile\", \"/kaggle/working/qwen25-coder-7b-cyber/gguf/cyber-llm-f16.gguf\",\n",
    "        \"--outtype\", \"f16\",\n",
    "    ]\n",
    "    \n",
    "    print(f\"Converting to f16...\")\n",
    "    result = subprocess.run(cmd, capture_output=True, text=True, timeout=600)\n",
    "    if result.returncode == 0:\n",
    "        print(\"✅ f16 conversion complete\")\n",
    "        \n",
    "        # Quantize\n",
